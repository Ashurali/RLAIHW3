# Copy this file to deploy/server.env and fill in your server's details.
# deploy/server.env is gitignored (do not commit credentials/host info).

SSH_HOST=your.server.hostname     # e.g. 140.113.x.x or lab-gpu.example.edu
SSH_USER=youruser
SSH_PORT=22

# Auth is key-based (OpenSSH cannot take a password from a file, and there are
# many ssh/scp calls). One-time, from PowerShell on the laptop:
#   ssh-keygen -t ed25519        # if you have no key yet (Enter through prompts)
#   $pub = Get-Content "$env:USERPROFILE\.ssh\id_ed25519.pub"
#   ssh USER@HOST "mkdir -p ~/.ssh && chmod 700 ~/.ssh && echo '$pub' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys"
# (asks for your password the last time). Then SSH_KEY can stay blank to use the
# default ~/.ssh/id_ed25519, or set an explicit private-key path here.
SSH_KEY=

# Remote directory where the repo will live (created automatically).
# Absolute paths are fine, e.g. /home/nycu813/mike/RLAIHW3
REMOTE_DIR=~/hw3rl

# Name of the Python venv created on the server (under REMOTE_DIR).
REMOTE_VENV=hw3

# Optional: interpreter used to build the venv. Leave blank to auto-pick
# python3.12 -> 3.11 -> 3.10 (preferred over a conda base 3.13 for wheel
# coverage). Set e.g. REMOTE_PY_BIN=python3.12 to force one.
REMOTE_PY_BIN=
