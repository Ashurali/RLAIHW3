# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Virtual environments
hw3/
.venv/
venv/
env/

# Large training artifacts (regenerated on the server; keep them out of git).
# Lightweight, report-relevant outputs (metrics.csv, curve.png, eval.json,
# config.yaml, gameplay.gif) are kept -- see the negations below.
*.zip
*.pkl
*.pth
results/**/tb/
results/**/checkpoints/
results/**/best_model/
events.out.tfevents.*

# Keep the small report-relevant per-run outputs even though *.zip etc. are ignored.
!results/**/metrics.csv
!results/**/curve.png
!results/**/eval.json
!results/**/config.yaml
!results/**/gameplay.gif

# Deploy / SSH workflow
# (gitignore has no inline comments — keep patterns on their own lines)
# connection details — never commit
deploy/server.env
# training logs fetched back from the server
logs/
# upload / fetch tarballs
*.tgz
*.pid

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
